CLIENT_NAME="Darcy's Business"
CLIENT_SLUG="darcy"
CLIENT_OWNER="Darcy Mitchell"
CLIENT_ROLE="Content creator · YouTube · Skool"
CLIENT_INITIALS="DM"
CLIENT_TIMEZONE="America/Chicago"
CLIENT_TZ_LABEL="Chicago"
CLIENT_DESCRIPTION="Content creator · YouTube · Skool"

# Auth between Hermes and the dashboard. Hermes POSTs every event with
# Authorization: Bearer ${INGEST_API_KEY}
INGEST_API_KEY=

# If set, the dashboard POSTs approve/reject decisions back to this URL
HERMES_API_URL=
HERMES_API_KEY=

# Slack — optional. Without these, dashboard works fully; just no Slack push.
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
SLACK_SIGNING_SECRET=

# next-auth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Client login password (single-tenant)
DASHBOARD_PASSWORD=

# Owner login password — when set, logging in with this password unlocks /admin
# (agent / skill / memory / cron management). Hidden from the client UI when
# you log in with DASHBOARD_PASSWORD.
OWNER_PASSWORD=

# Absolute path to the host's Hermes install. Mission Control mounts this
# read-write so the /admin UI can read & edit ~/.hermes/* files (config.yaml,
# skills/, memory/MEMORY.md, etc.). Leave default for typical Linux installs.
HERMES_DIR=/root/.hermes

# Storage
DATABASE_URL="file:./data/db.sqlite"

# Server
PORT=3000
